// VocalIQ multi-tenant schema (DATA-MODEL.md). Golden rule #1: every tenant-owned
// table carries `tenantId` + an index on it + an RLS policy (packages/db/rls/).
// RLS is the safety net; application-layer tenant filters are the front door.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums (mirror @vocaliq/shared enums.ts — keep 1:1)
// ─────────────────────────────────────────────────────────────────────────────

enum TenantType {
  PLATFORM
  RESELLER
  CUSTOMER
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum Role {
  SUPER_ADMIN
  RESELLER_ADMIN
  OWNER
  ADMIN
  BUILDER
  ANALYST
  AGENT
  BILLING
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum Provider {
  OPENAI
  ANTHROPIC
  GEMINI
  GROK
  OPENROUTER
  ELEVENLABS
  PLAYHT
  CARTESIA
  DEEPGRAM
  ASSEMBLYAI
  TWILIO
  TELNYX
  PLIVO
  WHATSAPP
  MESSENGER
  LIVEKIT
}

enum Capability {
  llm
  tts
  stt
  telephony
  embedding
}

enum AgentType {
  INBOUND
  OUTBOUND
  MIXED
}

enum AgentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum KbSourceType {
  PDF
  DOC
  TXT
  URL
  TEXT
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallChannel {
  PSTN
  WEB
  SIP
  WHATSAPP
  MESSENGER
}

enum CallStatus {
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  VOICEMAIL
  NO_ANSWER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  HOT
  WARM
  COLD
  BOOKED
  LOST
}

enum PhoneNumberSource {
  POOL
  PURCHASED
  SIP
}

enum AppointmentStatus {
  BOOKED
  RESCHEDULED
  CANCELLED
  COMPLETED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum IntegrationType {
  HUBSPOT
  SALESFORCE
  ZENDESK
  GOOGLE
  ZAPIER
  WEBHOOK
}

enum FeatureFlagScope {
  GLOBAL
  PLAN
  TENANT
}

enum MessageChannel {
  WHATSAPP
  SMS
  EMAIL
  TELEGRAM
  MESSENGER
  INSTAGRAM
  RCS
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

// ─────────────────────────────────────────────────────────────────────────────
// Core tenancy
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id             String       @id @default(uuid()) @db.Uuid
  type           TenantType
  parentTenantId String?      @db.Uuid
  parent         Tenant?      @relation("TenantHierarchy", fields: [parentTenantId], references: [id], onDelete: SetNull)
  children       Tenant[]     @relation("TenantHierarchy")
  name           String
  slug           String       @unique
  status         TenantStatus @default(TRIAL)
  branding       Json         @default("{}")
  customDomain   String?      @unique
  settings       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships         Membership[]
  agents              Agent[]
  providerCredentials ProviderCredential[]
  voices              Voice[]
  knowledgeBases      KnowledgeBase[]
  contacts            Contact[]
  leads               Lead[]
  phoneNumbers        PhoneNumber[]
  sipTrunks           SipTrunk[]
  calls               Call[]
  campaigns           Campaign[]
  appointments        Appointment[]
  forms               Form[]
  formSubmissions     FormSubmission[]
  plans               Plan[]
  subscriptions       Subscription[]
  wallet              Wallet?
  usageRecords        UsageRecord[]
  invoices            Invoice[]
  integrations        Integration[]
  webhooks            Webhook[]
  supportTickets      SupportTicket[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  featureFlags        FeatureFlag[]
  ssoConnection       SsoConnection?
  consentRecords      ConsentRecord[]
  suppressions        Suppression[]
  callLatencies       CallLatency[]
  agentPresences      AgentPresence[]
  transferRequests    TransferRequest[]
  abuseCases          AbuseCase[]
  sentimentRules      SentimentRule[]
  sentimentEvents     SentimentEvent[]
  coachNotes          CoachNote[]
  callSignals         CallSignal[]
  intelConfig         ConversationIntelConfig?
  customModels        CustomModel[]
  payments            Payment[]
  callbacks           Callback[]
  revenueEvents       RevenueEvent[]
  outcomePrices       OutcomePrice[]
  billableOutcomes    BillableOutcome[]
  marketplaceListings  MarketplaceListing[]  @relation("MarketplaceCreator")
  marketplacePurchases MarketplacePurchase[] @relation("MarketplaceBuyer")
  marketplaceReviews   MarketplaceReview[]   @relation("MarketplaceReviewer")
  developerApps        DeveloperApp[]        @relation("AppDeveloper")
  appInstalls          AppInstall[]          @relation("AppInstaller")
  workflows            Workflow[]
  workflowRuns         WorkflowRun[]
  workflowRunSteps     WorkflowRunStep[]
  analyticsExports     AnalyticsExport[]
  exportSchedules      ExportSchedule[]
  transcriptTranslations TranscriptTranslation[]
  translationCache       TranslationCache[]
  learningRuns           LearningRun[]
  copilotSessions        CopilotSession[]
  battlecards            Battlecard[]
  voiceprints            Voiceprint[]
  voiceprintAudits       VoiceprintAudit[]
  avatars                Avatar[]
  avatarSessions         AvatarSession[]
  flows               Flow[]
  flowVersions        FlowVersion[]
  transcripts         Transcript[]
  agentMemories       AgentMemory[]
  kbChunks            KbChunk[]
  resellerMargins     ResellerMargin[]     @relation("ResellerOfMargin")
  childMargins        ResellerMargin[]     @relation("ChildOfMargin")
  squads              Squad[]
  squadMembers        SquadMember[]
  experiments         Experiment[]
  testScenarios       TestScenario[]
  testRuns            TestRun[]
  qaRubrics           QaRubric[]
  qaScores            QaScore[]
  messageTemplates    MessageTemplate[]
  messages            Message[]
  messagingOptOuts    MessagingOptOut[]
  mcpServers          McpServer[]
  automations         Automation[]
  apiKeys             ApiKey[]
  walletLedger        WalletLedger[]
  creditGrants        CreditGrant[]
  whatsappCalls        WhatsAppCall[]
  whatsappCallEvents   WhatsAppCallEvent[]
  whatsappCallVolumes  WhatsAppCallVolume[]
  whatsappCallPermissions WhatsAppCallPermission[]
  whatsappPermissionRequests WhatsAppPermissionRequest[]

  @@index([parentTenantId])
  @@index([type])
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  email          String       @unique
  name           String?
  passwordHash   String? // bcrypt hash for self-hosted email/password auth (Day 30 stack pivot)
  authProviderId String?      @unique // legacy external auth id (was Clerk); null for self-hosted users
  imageUrl       String?
  mfaEnabled     Boolean      @default(false)
  theme          Json? // per-user appearance theme (UX-12): preset + custom colours + radius/density/motion/font
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  memberships    Membership[]

  @@index([authProviderId])
}

// Join of a user to a tenant with a role. Tenant-scoped.
model Membership {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @db.Uuid
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Provider keys (envelope-encrypted; never plaintext)
// ─────────────────────────────────────────────────────────────────────────────

model ProviderCredential {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String?  @db.Uuid // null = platform-level key
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider     Provider
  encryptedKey Bytes // envelope-encrypted ciphertext ONLY
  byok         Boolean  @default(false)
  meta         Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([provider])
}

// Load-balanced platform key pool (not tenant-scoped — platform infrastructure).
model PlatformApiKeyPool {
  id            String    @id @default(uuid()) @db.Uuid
  provider      Provider
  label         String? // operator label (last-4 hint, not the key)
  encryptedKey  Bytes
  weight        Int       @default(1)
  active        Boolean   @default(true)
  failureCount  Int       @default(0) // consecutive failures → ejection (Day 38)
  lastFailureAt DateTime?
  lastUsedAt    DateTime?

  @@index([provider, active])
}

// ─────────────────────────────────────────────────────────────────────────────
// Agents & flows
// ─────────────────────────────────────────────────────────────────────────────

model Agent {
  id                 String      @id @default(uuid()) @db.Uuid
  tenantId           String      @db.Uuid
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  persona            Json        @default("{}")
  defaultVoiceId     String?     @db.Uuid
  fallbackVoiceId    String?     @db.Uuid
  customModelId      String?     @db.Uuid // Day 76: a per-tenant custom/fine-tuned LLM profile
  languages          String[]    @default([])
  llmPolicy          Json        @default("{}")
  emotionPolicy      Json        @default("{}") // Day 77: per-agent emotion-aware voice modulation
  turnTimeoutMs      Int         @default(1500)
  maxCallDurationSec Int         @default(600) // hard call-length cap (Day 38)
  maxSilenceSec      Int         @default(15) // dead-air auto-hangup (0 disables)
  endOnVoicemail     Boolean     @default(true)
  bannedWordsAction  String      @default("flag") // flag | redact | block
  keyTerms           String[]    @default([]) // custom STT vocabulary boost (Day 39)
  noVerbatim         Boolean     @default(false) // store a filler-stripped clean transcript
  type               AgentType   @default(INBOUND)
  status             AgentStatus @default(DRAFT)
  memoryEnabled      Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  flows          Flow[]
  calls          Call[]
  campaigns      Campaign[]
  agentMemories  AgentMemory[]
  phoneNumbers   PhoneNumber[]
  knowledgeBases KnowledgeBase[]
  squadMembers   SquadMember[]
  testScenarios  TestScenario[]
  qaRubrics      QaRubric[]
  testRuns       TestRun[]
  mcpServers     McpServer[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model Flow {
  id        String        @id @default(uuid()) @db.Uuid
  tenantId  String        @db.Uuid
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId   String        @db.Uuid
  agent     Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean       @default(false)
  createdAt DateTime      @default(now())
  versions  FlowVersion[]

  @@index([tenantId])
  @@index([agentId])
}

model FlowVersion {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid // denormalized from Flow for uniform RLS
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flowId      String    @db.Uuid
  flow        Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  version     Int
  graph       Json      @default("{}") // React Flow nodes + edges
  publishedAt DateTime?
  createdBy   String?   @db.Uuid
  createdAt   DateTime  @default(now())
  calls       Call[]

  @@unique([flowId, version])
  @@index([tenantId])
  @@index([flowId])
}

model Voice {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String?  @db.Uuid // null = public/preset
  tenant          Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider        Provider
  providerVoiceId String
  name            String
  language        String?
  gender          String?
  age             String?
  accent          String?
  style           String?
  isCloned        Boolean  @default(false)
  approved        Boolean  @default(false) // cloned voices stay unusable until an operator approves (Day 26)
  consentRef      Json?
  settings        Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Squads (multi-agent teams — Day 27)
// ─────────────────────────────────────────────────────────────────────────────

model Squad {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @db.Uuid
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  entryAgentId String?       @db.Uuid // the specialist that answers first
  handoffRules Json          @default("[]") // [{ fromAgentId, on, toAgentId }] — routes turns between specialists
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  members      SquadMember[]

  @@index([tenantId])
}

model SquadMember {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  squadId   String   @db.Uuid
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  agentId   String   @db.Uuid
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role      String // receptionist / booking / billing / …
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([squadId, agentId])
  @@index([tenantId])
  @@index([squadId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Agent testing — scenarios + eval runs (Day 33)
// ─────────────────────────────────────────────────────────────────────────────

model TestScenario {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId    String   @db.Uuid
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name       String
  definition Json     @default("{}") // the Scenario { name, caller, assertions }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([agentId])
}

model TestRun {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId   String   @db.Uuid
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  total     Int      @default(0)
  passed    Int      @default(0)
  passRate  Float    @default(0)
  report    Json     @default("{}") // the SuiteReport
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([agentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// QA scoring (Day 43) — tenant-defined rubrics, LLM-evaluated per call
// ─────────────────────────────────────────────────────────────────────────────

model QaRubric {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId      String?   @db.Uuid // optional scope: null = applies to every agent
  agent        Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  name         String
  criteria     Json      @default("[]") // [{ key, description, weight }]
  samplingRate Float     @default(1) // 0..1 fraction of calls to score (cost-aware)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  scores       QaScore[]

  @@index([tenantId])
  @@index([agentId])
}

model QaScore {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId    String   @db.Uuid
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  rubricId  String   @db.Uuid
  rubric    QaRubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  overall   Float // weighted 0..100
  criteria  Json     @default("[]") // [{ key, score (0..1), weight, reason }]
  model     String // evaluator model id (audit)
  createdAt DateTime @default(now())

  @@unique([callId, rubricId]) // one score per rubric per call (idempotent re-scoring)
  @@index([tenantId])
  @@index([tenantId, rubricId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Messaging (Day 44) — WhatsApp/SMS templates, messages, opt-outs
// ─────────────────────────────────────────────────────────────────────────────

model MessageTemplate {
  id                 String         @id @default(uuid()) @db.Uuid
  tenantId           String         @db.Uuid
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel            MessageChannel
  name               String
  language           String         @default("en")
  category           String         @default("utility")
  body               String // may contain {{variables}}
  variables          String[]       @default([]) // extracted {{var}} names (audit/UX)
  approvalStatus     String         @default("APPROVED") // WhatsApp templates need Meta approval
  providerTemplateId String?
  active             Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  messages           Message[]

  @@unique([tenantId, channel, name, language])
  @@index([tenantId])
}

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @db.Uuid
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel           MessageChannel
  direction         MessageDirection
  status            MessageStatus    @default(QUEUED)
  toAddr            String
  fromAddr          String?
  body              String
  templateId        String?          @db.Uuid
  template          MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  contactId         String?          @db.Uuid // soft link (app + RLS scoped; no FK)
  callId            String?          @db.Uuid
  campaignId        String?          @db.Uuid
  providerMessageId String? // id from Twilio/Meta for status correlation
  costUsd           Float            @default(0)
  error             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([providerMessageId])
}

model MessagingOptOut {
  id        String         @id @default(uuid()) @db.Uuid
  tenantId  String         @db.Uuid
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel   MessageChannel
  phone     String
  createdAt DateTime       @default(now())

  @@unique([tenantId, channel, phone])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MCP / external tool servers (Day 46) — trust-context-gated, per-tool timeouts
// ─────────────────────────────────────────────────────────────────────────────

model McpServer {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId          String?  @db.Uuid // optional scope: null = tenant-wide
  agent            Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  name             String
  url              String
  transport        String   @default("http") // http | sse
  trustContext     String   @default("UNKNOWN") // LOW | HIGH | UNKNOWN
  timeoutMs        Int      @default(30000)
  authHeaderCipher String? // sealed auth header value — NEVER returned to a client
  tools            Json     @default("[]") // discovered tool descriptors [{ name, description, readOnly, destructive }]
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@index([agentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Cross-channel automations (Day 47) — trigger → multi-step actions
// ─────────────────────────────────────────────────────────────────────────────

model Automation {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  event     String // call_ended | disposition_set | lead_status_changed
  filters   Json     @default("{}") // { disposition?, leadStatus?, agentId? }
  actions   Json     @default("[]") // [{ type, config }] — send_message | crm_sync | webhook | task | notify
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, event])
}

// ─────────────────────────────────────────────────────────────────────────────
// Public API keys (Day 48) — tenant-scoped, hashed, rate-limited + metered
// ─────────────────────────────────────────────────────────────────────────────

model ApiKey {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  prefix          String // display hint (e.g. "vq_live_ab12cd34"); NOT the secret
  hashedKey       String    @unique // sha256(secret) — the plaintext is shown once, never stored
  scopes          String[]  @default([]) // e.g. ["agents:read","calls:read"]
  rateLimitPerMin Int       @default(60)
  requestCount    Int       @default(0) // usage metering
  lastUsedAt      DateTime?
  revoked         Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Knowledge (RAG, pgvector)
// ─────────────────────────────────────────────────────────────────────────────

model KnowledgeBase {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @db.Uuid
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId    String?      @db.Uuid
  agent      Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  name       String
  sourceType KbSourceType
  createdAt  DateTime     @default(now())
  chunks     KbChunk[]

  @@index([tenantId])
  @@index([agentId])
}

model KbChunk {
  id        String                       @id @default(uuid()) @db.Uuid
  kbId      String                       @db.Uuid
  kb        KnowledgeBase                @relation(fields: [kbId], references: [id], onDelete: Cascade)
  tenantId  String                       @db.Uuid
  tenant    Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  content   String
  embedding Unsupported("vector(1536)")? // pgvector; HNSW index added in RLS/extra SQL
  metadata  Json                         @default("{}")
  createdAt DateTime                     @default(now())

  @@index([tenantId])
  @@index([kbId])
}

model AgentMemory {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId    String   @db.Uuid
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  contactId  String   @db.Uuid
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  summary    String?
  facts      Json     @default("{}")
  lastCallId String?  @db.Uuid
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, agentId, contactId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Leads, contacts & pipeline
// ─────────────────────────────────────────────────────────────────────────────

model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone     String?
  name      String?
  email     String?
  fields    Json     @default("{}")
  tags      String[] @default([])
  source    String?
  dnc       Boolean  @default(false)
  kycStatus String?
  // Email consent (Day 72) — the lawful basis to email; never email without it.
  emailConsent       Boolean   @default(false)
  emailConsentSource String? // imported | captured_on_call | web_form
  emailConsentAt     DateTime?
  unsubscribedAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads           Lead[]
  calls           Call[]
  appointments    Appointment[]
  agentMemories   AgentMemory[]
  formSubmissions FormSubmission[]
  whatsappCallPermissions WhatsAppCallPermission[]

  @@index([tenantId])
  @@index([tenantId, phone])
}

model Lead {
  id            String     @id @default(uuid()) @db.Uuid
  tenantId      String     @db.Uuid
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId     String     @db.Uuid
  contact       Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status        LeadStatus @default(NEW)
  score         Int        @default(0)
  owner         String?    @db.Uuid
  pipelineStage String?
  dynamicVars   Json       @default("{}")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

// Public lead-capture forms (Day 37). A form has typed fields + routing (webhook /
// Google Sheet / trigger-a-call). Submissions are validated + sanitised, then turned into
// a Contact + Lead and optionally pushed to a Sheet (gated port) / webhook.
model Form {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  fields    Json     @default("[]") // FormField[] (validated by formConfigSchema)
  routing   Json     @default("{}") // { webhookUrl?, sheetId?, triggerAgentId? }
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions FormSubmission[]

  @@index([tenantId])
}

model FormSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  formId    String   @db.Uuid
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  contactId String?  @db.Uuid
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  values    Json     @default("{}") // sanitised cleaned values
  synced    Boolean  @default(false) // pushed to Sheet/webhook
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, formId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Telephony & calls
// ─────────────────────────────────────────────────────────────────────────────

model PhoneNumber {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String?           @db.Uuid
  tenant          Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider        Provider
  e164            String            @unique
