  capabilities    String[]          @default([])
  assignedAgentId String?           @db.Uuid
  assignedAgent   Agent?            @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  kycVerified     Boolean           @default(false)
  source          PhoneNumberSource @default(POOL)
  // Caller reputation + branded caller ID (Day 69).
  reputationScore     Int?      // 0–100 health score (null = never checked)
  spamLabel           String?   // clean | at_risk | flagged
  reputationCheckedAt DateTime?
  restedUntil         DateTime? // don't dial from this number until then (auto-remediation)
  warmupStartedAt     DateTime? // when volume ramp began (new-number warm-up)
  brandedCallerId     Json?     // CNAM / Rich Call Data { displayName, logoUrl, callReason }
