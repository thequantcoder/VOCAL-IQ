// VocalIQ multi-tenant schema (DATA-MODEL.md). Golden rule #1: every tenant-owned
// table carries `tenantId` + an index on it + an RLS policy (packages/db/rls/).
// RLS is the safety net; application-layer tenant filters are the front door.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums (mirror @vocaliq/shared enums.ts — keep 1:1)
// ─────────────────────────────────────────────────────────────────────────────

enum TenantType {
  PLATFORM
  RESELLER
  CUSTOMER
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

enum Role {
  SUPER_ADMIN
  RESELLER_ADMIN
  OWNER
  ADMIN
  BUILDER
  ANALYST
  AGENT
  BILLING
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum Provider {
  OPENAI
  ANTHROPIC
  GEMINI
  GROK
  OPENROUTER
  ELEVENLABS
  PLAYHT
  CARTESIA
  DEEPGRAM
  ASSEMBLYAI
  TWILIO
  TELNYX
  LIVEKIT
}

enum Capability {
  llm
  tts
  stt
  telephony
  embedding
}

enum AgentType {
  INBOUND
  OUTBOUND
  MIXED
}

enum AgentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum KbSourceType {
  PDF
  DOC
  TXT
  URL
  TEXT
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallChannel {
  PSTN
  WEB
  SIP
}

enum CallStatus {
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  VOICEMAIL
  NO_ANSWER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  HOT
  WARM
  COLD
  BOOKED
  LOST
}

enum PhoneNumberSource {
  POOL
  PURCHASED
  SIP
}

enum AppointmentStatus {
  BOOKED
  RESCHEDULED
  CANCELLED
  COMPLETED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum IntegrationType {
  HUBSPOT
  SALESFORCE
  ZENDESK
  GOOGLE
  ZAPIER
  WEBHOOK
}

enum FeatureFlagScope {
  GLOBAL
  PLAN
  TENANT
}

enum MessageChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  RECEIVED
}

// ─────────────────────────────────────────────────────────────────────────────
// Core tenancy
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id             String       @id @default(uuid()) @db.Uuid
  type           TenantType
  parentTenantId String?      @db.Uuid
  parent         Tenant?      @relation("TenantHierarchy", fields: [parentTenantId], references: [id], onDelete: SetNull)
  children       Tenant[]     @relation("TenantHierarchy")
  name           String
  slug           String       @unique
  status         TenantStatus @default(TRIAL)
  branding       Json         @default("{}")
  customDomain   String?      @unique
  settings       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships         Membership[]
  agents              Agent[]
  providerCredentials ProviderCredential[]
  voices              Voice[]
  knowledgeBases      KnowledgeBase[]
  contacts            Contact[]
  leads               Lead[]
  phoneNumbers        PhoneNumber[]
  sipTrunks           SipTrunk[]
  calls               Call[]
  campaigns           Campaign[]
  appointments        Appointment[]
  forms               Form[]
  formSubmissions     FormSubmission[]
  plans               Plan[]
  subscriptions       Subscription[]
  wallet              Wallet?
  usageRecords        UsageRecord[]
  invoices            Invoice[]
  integrations        Integration[]
  webhooks            Webhook[]
  supportTickets      SupportTicket[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  featureFlags        FeatureFlag[]
  ssoConnection       SsoConnection?
  consentRecords      ConsentRecord[]
  suppressions        Suppression[]
  callLatencies       CallLatency[]
  agentPresences      AgentPresence[]
  transferRequests    TransferRequest[]
  abuseCases          AbuseCase[]
  flows               Flow[]
  flowVersions        FlowVersion[]
  transcripts         Transcript[]
  agentMemories       AgentMemory[]
  kbChunks            KbChunk[]
  resellerMargins     ResellerMargin[]     @relation("ResellerOfMargin")
  childMargins        ResellerMargin[]     @relation("ChildOfMargin")
  squads              Squad[]
  squadMembers        SquadMember[]
  experiments         Experiment[]
  testScenarios       TestScenario[]
  testRuns            TestRun[]
  qaRubrics           QaRubric[]
  qaScores            QaScore[]
  messageTemplates    MessageTemplate[]
  messages            Message[]
  messagingOptOuts    MessagingOptOut[]
  mcpServers          McpServer[]
  automations         Automation[]
  apiKeys             ApiKey[]
  walletLedger        WalletLedger[]

  @@index([parentTenantId])
  @@index([type])
}

model User {
  id             String       @id @default(uuid()) @db.Uuid
  email          String       @unique
  name           String?
  passwordHash   String? // bcrypt hash for self-hosted email/password auth (Day 30 stack pivot)
  authProviderId String?      @unique // legacy external auth id (was Clerk); null for self-hosted users
  imageUrl       String?
  mfaEnabled     Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  memberships    Membership[]

  @@index([authProviderId])
}

// Join of a user to a tenant with a role. Tenant-scoped.
model Membership {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @db.Uuid
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Provider keys (envelope-encrypted; never plaintext)
// ─────────────────────────────────────────────────────────────────────────────

model ProviderCredential {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String?  @db.Uuid // null = platform-level key
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider     Provider
  encryptedKey Bytes // envelope-encrypted ciphertext ONLY
  byok         Boolean  @default(false)
  meta         Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([provider])
}

// Load-balanced platform key pool (not tenant-scoped — platform infrastructure).
model PlatformApiKeyPool {
  id            String    @id @default(uuid()) @db.Uuid
  provider      Provider
  label         String? // operator label (last-4 hint, not the key)
  encryptedKey  Bytes
  weight        Int       @default(1)
  active        Boolean   @default(true)
  failureCount  Int       @default(0) // consecutive failures → ejection (Day 38)
  lastFailureAt DateTime?
  lastUsedAt    DateTime?

  @@index([provider, active])
}

// ─────────────────────────────────────────────────────────────────────────────
// Agents & flows
// ─────────────────────────────────────────────────────────────────────────────

model Agent {
  id                 String      @id @default(uuid()) @db.Uuid
  tenantId           String      @db.Uuid
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  persona            Json        @default("{}")
  defaultVoiceId     String?     @db.Uuid
  fallbackVoiceId    String?     @db.Uuid
  languages          String[]    @default([])
  llmPolicy          Json        @default("{}")
  turnTimeoutMs      Int         @default(1500)
  maxCallDurationSec Int         @default(600) // hard call-length cap (Day 38)
  maxSilenceSec      Int         @default(15) // dead-air auto-hangup (0 disables)
  endOnVoicemail     Boolean     @default(true)
  bannedWordsAction  String      @default("flag") // flag | redact | block
  keyTerms           String[]    @default([]) // custom STT vocabulary boost (Day 39)
  noVerbatim         Boolean     @default(false) // store a filler-stripped clean transcript
  type               AgentType   @default(INBOUND)
  status             AgentStatus @default(DRAFT)
  memoryEnabled      Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  flows          Flow[]
  calls          Call[]
  campaigns      Campaign[]
  agentMemories  AgentMemory[]
  phoneNumbers   PhoneNumber[]
  knowledgeBases KnowledgeBase[]
  squadMembers   SquadMember[]
  testScenarios  TestScenario[]
  qaRubrics      QaRubric[]
  testRuns       TestRun[]
  mcpServers     McpServer[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model Flow {
  id        String        @id @default(uuid()) @db.Uuid
  tenantId  String        @db.Uuid
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId   String        @db.Uuid
  agent     Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean       @default(false)
  createdAt DateTime      @default(now())
  versions  FlowVersion[]

  @@index([tenantId])
  @@index([agentId])
}

model FlowVersion {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid // denormalized from Flow for uniform RLS
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flowId      String    @db.Uuid
  flow        Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  version     Int
  graph       Json      @default("{}") // React Flow nodes + edges
  publishedAt DateTime?
  createdBy   String?   @db.Uuid
  createdAt   DateTime  @default(now())
  calls       Call[]

  @@unique([flowId, version])
  @@index([tenantId])
  @@index([flowId])
}

model Voice {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String?  @db.Uuid // null = public/preset
  tenant          Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider        Provider
  providerVoiceId String
  name            String
  language        String?
  gender          String?
  age             String?
  accent          String?
  style           String?
  isCloned        Boolean  @default(false)
  approved        Boolean  @default(false) // cloned voices stay unusable until an operator approves (Day 26)
  consentRef      Json?
  settings        Json     @default("{}")
  createdAt       DateTime @default(now())

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Squads (multi-agent teams — Day 27)
// ─────────────────────────────────────────────────────────────────────────────

model Squad {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @db.Uuid
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  entryAgentId String?       @db.Uuid // the specialist that answers first
  handoffRules Json          @default("[]") // [{ fromAgentId, on, toAgentId }] — routes turns between specialists
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  members      SquadMember[]

  @@index([tenantId])
}

model SquadMember {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  squadId   String   @db.Uuid
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  agentId   String   @db.Uuid
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role      String // receptionist / booking / billing / …
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([squadId, agentId])
  @@index([tenantId])
  @@index([squadId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Agent testing — scenarios + eval runs (Day 33)
// ─────────────────────────────────────────────────────────────────────────────

model TestScenario {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId    String   @db.Uuid
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name       String
  definition Json     @default("{}") // the Scenario { name, caller, assertions }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([agentId])
}

model TestRun {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId   String   @db.Uuid
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  total     Int      @default(0)
  passed    Int      @default(0)
  passRate  Float    @default(0)
  report    Json     @default("{}") // the SuiteReport
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([agentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// QA scoring (Day 43) — tenant-defined rubrics, LLM-evaluated per call
// ─────────────────────────────────────────────────────────────────────────────

model QaRubric {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId      String?   @db.Uuid // optional scope: null = applies to every agent
  agent        Agent?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  name         String
  criteria     Json      @default("[]") // [{ key, description, weight }]
  samplingRate Float     @default(1) // 0..1 fraction of calls to score (cost-aware)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  scores       QaScore[]

  @@index([tenantId])
  @@index([agentId])
}

model QaScore {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId    String   @db.Uuid
  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  rubricId  String   @db.Uuid
  rubric    QaRubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  overall   Float // weighted 0..100
  criteria  Json     @default("[]") // [{ key, score (0..1), weight, reason }]
  model     String // evaluator model id (audit)
  createdAt DateTime @default(now())

  @@unique([callId, rubricId]) // one score per rubric per call (idempotent re-scoring)
  @@index([tenantId])
  @@index([tenantId, rubricId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Messaging (Day 44) — WhatsApp/SMS templates, messages, opt-outs
// ─────────────────────────────────────────────────────────────────────────────

model MessageTemplate {
  id                 String         @id @default(uuid()) @db.Uuid
  tenantId           String         @db.Uuid
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel            MessageChannel
  name               String
  language           String         @default("en")
  category           String         @default("utility")
  body               String // may contain {{variables}}
  variables          String[]       @default([]) // extracted {{var}} names (audit/UX)
  approvalStatus     String         @default("APPROVED") // WhatsApp templates need Meta approval
  providerTemplateId String?
  active             Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  messages           Message[]

  @@unique([tenantId, channel, name, language])
  @@index([tenantId])
}

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  tenantId          String           @db.Uuid
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel           MessageChannel
  direction         MessageDirection
  status            MessageStatus    @default(QUEUED)
  toAddr            String
  fromAddr          String?
  body              String
  templateId        String?          @db.Uuid
  template          MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  contactId         String?          @db.Uuid // soft link (app + RLS scoped; no FK)
  callId            String?          @db.Uuid
  campaignId        String?          @db.Uuid
  providerMessageId String? // id from Twilio/Meta for status correlation
  costUsd           Float            @default(0)
  error             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([providerMessageId])
}

model MessagingOptOut {
  id        String         @id @default(uuid()) @db.Uuid
  tenantId  String         @db.Uuid
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel   MessageChannel
  phone     String
  createdAt DateTime       @default(now())

  @@unique([tenantId, channel, phone])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MCP / external tool servers (Day 46) — trust-context-gated, per-tool timeouts
// ─────────────────────────────────────────────────────────────────────────────

model McpServer {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId          String?  @db.Uuid // optional scope: null = tenant-wide
  agent            Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  name             String
  url              String
  transport        String   @default("http") // http | sse
  trustContext     String   @default("UNKNOWN") // LOW | HIGH | UNKNOWN
  timeoutMs        Int      @default(30000)
  authHeaderCipher String? // sealed auth header value — NEVER returned to a client
  tools            Json     @default("[]") // discovered tool descriptors [{ name, description, readOnly, destructive }]
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@index([agentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Cross-channel automations (Day 47) — trigger → multi-step actions
// ─────────────────────────────────────────────────────────────────────────────

model Automation {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  event     String // call_ended | disposition_set | lead_status_changed
  filters   Json     @default("{}") // { disposition?, leadStatus?, agentId? }
  actions   Json     @default("[]") // [{ type, config }] — send_message | crm_sync | webhook | task | notify
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, event])
}

// ─────────────────────────────────────────────────────────────────────────────
// Public API keys (Day 48) — tenant-scoped, hashed, rate-limited + metered
// ─────────────────────────────────────────────────────────────────────────────

model ApiKey {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  prefix          String // display hint (e.g. "vq_live_ab12cd34"); NOT the secret
  hashedKey       String    @unique // sha256(secret) — the plaintext is shown once, never stored
  scopes          String[]  @default([]) // e.g. ["agents:read","calls:read"]
  rateLimitPerMin Int       @default(60)
  requestCount    Int       @default(0) // usage metering
  lastUsedAt      DateTime?
  revoked         Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Knowledge (RAG, pgvector)
// ─────────────────────────────────────────────────────────────────────────────

model KnowledgeBase {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @db.Uuid
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId    String?      @db.Uuid
  agent      Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  name       String
  sourceType KbSourceType
  createdAt  DateTime     @default(now())
  chunks     KbChunk[]

  @@index([tenantId])
  @@index([agentId])
}

model KbChunk {
  id        String                       @id @default(uuid()) @db.Uuid
  kbId      String                       @db.Uuid
  kb        KnowledgeBase                @relation(fields: [kbId], references: [id], onDelete: Cascade)
  tenantId  String                       @db.Uuid
  tenant    Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  content   String
  embedding Unsupported("vector(1536)")? // pgvector; HNSW index added in RLS/extra SQL
  metadata  Json                         @default("{}")
  createdAt DateTime                     @default(now())

  @@index([tenantId])
  @@index([kbId])
}

model AgentMemory {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId    String   @db.Uuid
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  contactId  String   @db.Uuid
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  summary    String?
  facts      Json     @default("{}")
  lastCallId String?  @db.Uuid
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, agentId, contactId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Leads, contacts & pipeline
// ─────────────────────────────────────────────────────────────────────────────

model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone     String?
  name      String?
  email     String?
  fields    Json     @default("{}")
  tags      String[] @default([])
  source    String?
  dnc       Boolean  @default(false)
  kycStatus String?
  // Email consent (Day 72) — the lawful basis to email; never email without it.
  emailConsent       Boolean   @default(false)
  emailConsentSource String? // imported | captured_on_call | web_form
  emailConsentAt     DateTime?
  unsubscribedAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads           Lead[]
  calls           Call[]
  appointments    Appointment[]
  agentMemories   AgentMemory[]
  formSubmissions FormSubmission[]

  @@index([tenantId])
  @@index([tenantId, phone])
}

model Lead {
  id            String     @id @default(uuid()) @db.Uuid
  tenantId      String     @db.Uuid
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId     String     @db.Uuid
  contact       Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status        LeadStatus @default(NEW)
  score         Int        @default(0)
  owner         String?    @db.Uuid
  pipelineStage String?
  dynamicVars   Json       @default("{}")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

// Public lead-capture forms (Day 37). A form has typed fields + routing (webhook /
// Google Sheet / trigger-a-call). Submissions are validated + sanitised, then turned into
// a Contact + Lead and optionally pushed to a Sheet (gated port) / webhook.
model Form {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  fields    Json     @default("[]") // FormField[] (validated by formConfigSchema)
  routing   Json     @default("{}") // { webhookUrl?, sheetId?, triggerAgentId? }
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions FormSubmission[]

  @@index([tenantId])
}

model FormSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  formId    String   @db.Uuid
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  contactId String?  @db.Uuid
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  values    Json     @default("{}") // sanitised cleaned values
  synced    Boolean  @default(false) // pushed to Sheet/webhook
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, formId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Telephony & calls
// ─────────────────────────────────────────────────────────────────────────────

model PhoneNumber {
  id              String            @id @default(uuid()) @db.Uuid
  tenantId        String?           @db.Uuid
  tenant          Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider        Provider
  e164            String            @unique
  capabilities    String[]          @default([])
  assignedAgentId String?           @db.Uuid
  assignedAgent   Agent?            @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  kycVerified     Boolean           @default(false)
  source          PhoneNumberSource @default(POOL)
  // Caller reputation + branded caller ID (Day 69).
  reputationScore     Int?      // 0–100 health score (null = never checked)
  spamLabel           String?   // clean | at_risk | flagged
  reputationCheckedAt DateTime?
  restedUntil         DateTime? // don't dial from this number until then (auto-remediation)
  warmupStartedAt     DateTime? // when volume ramp began (new-number warm-up)
  brandedCallerId     Json?     // CNAM / Rich Call Data { displayName, logoUrl, callReason }
  createdAt       DateTime          @default(now())

  @@index([tenantId])
}

model SipTrunk {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  providerTemplate String
  name             String   @default("") // operator label (Day 35)
  host             String   @default("") // SIP host/gateway (non-secret)
  port             Int      @default(5060)
  encryptedCreds   Bytes // envelope-encrypted ciphertext ONLY (authUsername/authPassword/sipDomain)
  transport        String   @default("TLS")
  inbound          Boolean  @default(true)
  outbound         Boolean  @default(true)
  concurrencyLimit Int      @default(10)
  createdAt        DateTime @default(now())

  @@index([tenantId])
}

model Call {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @db.Uuid
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId       String        @db.Uuid
  agent         Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  flowVersionId String?       @db.Uuid
  flowVersion   FlowVersion?  @relation(fields: [flowVersionId], references: [id], onDelete: SetNull)
  contactId     String?       @db.Uuid
  contact       Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  direction     CallDirection
  channel       CallChannel
  status        CallStatus    @default(QUEUED)
  startedAt     DateTime?
  endedAt       DateTime?
  durationSec   Int?
  recordingUrl  String?
  attestation   String? // STIR/SHAKEN attestation level for this call (A|B|C|none) — Day 69
  // AI disclosure compliance (Day 71) — the defensible record of what was disclosed + opt-out.
  disclosureText String?
  disclosedAt    DateTime?
  humanOptOutAt  DateTime?
  disposition   String?
  sentiment     Float?
  costBreakdown Json          @default("{}") // {stt, llm, tts, telephony, total}
  experimentId  String?       @db.Uuid // A/B experiment this call was routed through (Day 30)
  variant       String? // the variant id assigned for that experiment
  experiment    Experiment?   @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())

  transcript   Transcript?
  usageRecords UsageRecord[]
  qaScores     QaScore[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([agentId])
  @@index([experimentId, variant])
}

// ─────────────────────────────────────────────────────────────────────────────
// A/B experiments (Day 30)
// ─────────────────────────────────────────────────────────────────────────────

model Experiment {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  status    String   @default("DRAFT") // DRAFT / RUNNING / STOPPED
  metric    String   @default("conversion") // conversion / booking / csat
  variants  Json     @default("[]") // [{ id, label, weight, config }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calls Call[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model Transcript {
  id            String                       @id @default(uuid()) @db.Uuid
  callId        String                       @unique @db.Uuid
  call          Call                         @relation(fields: [callId], references: [id], onDelete: Cascade)
  tenantId      String                       @db.Uuid
  tenant        Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segments      Json                         @default("[]") // raw verbatim segments (always kept)
  cleanSegments Json? // no-verbatim clean copy (Day 39; null = not computed)
  searchText    String? // Day 42: flattened plain-text of segments for FTS + embedding source (null = not indexed)
  embedding     Unsupported("vector(1536)")? // Day 42: semantic-search vector over searchText; HNSW index in migration
  sources       Json                         @default("[]") // RAG citations used on the call [{chunkId,kbId,kbName,score,snippet}]
  summary       String?
  keywords      String[]                     @default([])
  topics        String[]                     @default([]) // post-call intel (Day 31)
  entities      Json                         @default("[]") // [{ type, value }]
  sentiment     String? // positive / neutral / negative
  intelAt       DateTime? // when post-call intel was generated (null = pending)
  createdAt     DateTime                     @default(now())

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Campaigns
// ─────────────────────────────────────────────────────────────────────────────

model Campaign {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  agentId      String   @db.Uuid
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status       String   @default("DRAFT")
  scheduleJson Json     @default("{}")
  pacing       Int      @default(1)
  concurrency  Int      @default(1)
  retryPolicy  Json     @default("{}")
  channelMix   Json     @default("{}")
  createdAt    DateTime @default(now())

  contacts CampaignContact[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model CampaignContact {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid
  campaignId      String    @db.Uuid
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId       String    @db.Uuid
  status          String    @default("PENDING")
  attempts        Int       @default(0)
  lastCallId      String?   @db.Uuid
  lastDisposition String? // last call outcome, drives the retry state machine (Day 28)
  nextAttemptAt   DateTime? // when this contact becomes due (null = due now)
  createdAt       DateTime  @default(now())

  @@unique([campaignId, contactId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([campaignId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Appointments
// ─────────────────────────────────────────────────────────────────────────────

model Appointment {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @db.Uuid
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId        String            @db.Uuid
  contact          Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  callId           String?           @db.Uuid
  startsAt         DateTime
  endsAt           DateTime
  status           AppointmentStatus @default(BOOKED)
  calendarProvider String?
  externalEventId  String?
  createdAt        DateTime          @default(now())

  @@index([tenantId])
  @@index([tenantId, startsAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Billing & metering
// ─────────────────────────────────────────────────────────────────────────────

model Plan {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String?        @db.Uuid // null = platform/global plan
  tenant            Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String
  priceMonthly      Int            @default(0) // minor units of `currency`
  currency          String         @default("USD")
  includedMinutes   Int            @default(0)
  agentLimit        Int            @default(1)
  numberLimit       Int            @default(0)
  sipLimit          Int            @default(0)
  features          Json           @default("{}")
  overageRatePerMin Int            @default(0) // minor units
  isResellerPlan    Boolean        @default(false)
  // No-code plan builder (Day 56): Stripe linkage + versioning for grandfathering.
  stripeProductId   String? // set on Stripe sync (gated until STRIPE_* keys)
  stripePriceId     String?
  version           Int            @default(1)
  active            Boolean        @default(true) // archived/superseded plans are inactive
  supersededById    String?        @db.Uuid // → the newer version that replaced this one
  supersededBy      Plan?          @relation("PlanVersion", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes        Plan[]         @relation("PlanVersion")
  createdAt         DateTime       @default(now())
  subscriptions     Subscription[]

  @@index([tenantId])
  @@index([tenantId, active])
}

model Subscription {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @db.Uuid
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId           String             @db.Uuid
  plan             Plan               @relation(fields: [planId], references: [id])
  status           SubscriptionStatus @default(TRIALING)
  processor        String?
  externalId       String?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())

  @@index([tenantId])
}

model Wallet {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @unique @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  balanceCents Int      @default(0) // prepaid credits (cached; = sum of ledger entries)
  bonusCents   Int      @default(0) // bonus / perk credits (Day 49; drained first)
  currency     String   @default("USD")
  autoRecharge Json     @default("{}")
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// Append-only wallet ledger (Day 53). Every top-up/charge/refund is an immutable entry; the
// balance is the sum. `idempotencyKey` is unique per tenant so replaying a charge NEVER
// double-debits (self-audit C). Integer minor units (cents) only — never floats.
model WalletLedger {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amountCents    Int // positive = credit, negative = debit
  currency       String   @default("USD")
  reason         String
  idempotencyKey String
  callId         String?  @db.Uuid // soft link to the charged call
  meta           Json     @default("{}") // pricing-chain snapshot for audit
  createdAt      DateTime @default(now())

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}

// One record per metered provider call. Timescale hypertable (see RLS/extra SQL);
// the partition column `ts` is part of the primary key so the hypertable is valid.
model UsageRecord {
  id         String     @default(uuid()) @db.Uuid
  tenantId   String     @db.Uuid
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId     String?    @db.Uuid
  call       Call?      @relation(fields: [callId], references: [id], onDelete: SetNull)
  provider   Provider
  capability Capability
  units      Float
  costUsd    Float
  byok       Boolean    @default(false)
  ts         DateTime   @default(now())

  @@id([id, ts])
  @@index([tenantId, ts])
  @@index([callId])
}

model Invoice {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period    String
  lineItems Json     @default("[]")
  total     Int      @default(0)
  status    String   @default("DRAFT")
  processor String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model ResellerMargin {
  id               String   @id @default(uuid()) @db.Uuid
  resellerTenantId String   @db.Uuid
  reseller         Tenant   @relation("ResellerOfMargin", fields: [resellerTenantId], references: [id], onDelete: Cascade)
  childTenantId    String   @db.Uuid
  child            Tenant   @relation("ChildOfMargin", fields: [childTenantId], references: [id], onDelete: Cascade)
  period           String
  revenue          Int      @default(0)
  cost             Int      @default(0)
  margin           Int      @default(0)
  createdAt        DateTime @default(now())

  @@index([resellerTenantId])
  @@index([childTenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Ops, integrations, audit
// ─────────────────────────────────────────────────────────────────────────────

model Integration {
  id        String          @id @default(uuid()) @db.Uuid
  tenantId  String          @db.Uuid
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      IntegrationType
  config    Json            @default("{}") // encrypted secrets within
  createdAt DateTime        @default(now())

  @@index([tenantId])
}

model Webhook {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url       String
  events    String[] @default([])
  secret    Bytes // encrypted
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model SupportTicket {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subject   String
  body      String
  status    String   @default("OPEN")
  priority  String   @default("NORMAL")
  assignee  String?  @db.Uuid
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?   @db.Uuid
  channel   String
  payload   Json      @default("{}")
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId])
  @@index([tenantId, userId])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUserId String?  @db.Uuid
  action      String
  target      String?
  meta        Json     @default("{}")
  ts          DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, ts])
}

/// A fraud/abuse case (Day 70) — the auditable record of an automated enforcement + its review.
model AbuseCase {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  score      Int
  action     String // throttle | pause_campaigns | suspend_tenant
  status     String   @default("open") // open | reviewing | resolved | dismissed
  reasons    String[] @default([])
  notes      String?
  resolvedBy String?  @db.Uuid
  resolvedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([tenantId, status])
  @@index([status])
}

/// Agent Desk presence (Day 67) — a human agent's live availability + skills for transfer routing.
model AgentPresence {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membershipId   String   @unique @db.Uuid
  userId         String   @db.Uuid
  status         String   @default("away") // available | away | busy
  skills         String[] @default([])
  activeCalls    Int      @default(0)
  lastAssignedAt DateTime?
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
}

/// A live call queued/routed to a human agent (Day 67). The Transfer node / escalation creates one.
model TransferRequest {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @db.Uuid
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId               String    @db.Uuid
  handoffType          String    @default("cold") // warm | cold
  strategy             String    @default("round_robin")
  requiredSkill        String?
  warmSummary          String?
  status               String    @default("queued") // queued | ringing | active | completed | abandoned
  assignedMembershipId String?   @db.Uuid
  waitStartedAt        DateTime  @default(now())
  answeredAt           DateTime?
  endedAt              DateTime?

  @@index([tenantId, status])
  @@index([callId])
}

/// Per-turn voice-loop latency samples (Day 63) — powers the latency dashboard + SLO enforcement.
model CallLatency {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId    String?  @db.Uuid
  sttMs     Int
  llmTtftMs Int
  ttsTtfaMs Int
  networkMs Int
  totalMs   Int
  provider  String?
  region    String?
  ts        DateTime @default(now())

  @@index([tenantId, ts])
}

/// Recording-disclosure / consent capture (Day 60). One row per consent event, region-aware.
model ConsentRecord {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactPhone String
  region       String
  channel      String   @default("voice")
  granted      Boolean
  basis        String?
  ts           DateTime @default(now())

  @@index([tenantId, contactPhone])
}

/// Do-Not-Call suppression (Day 60). tenantId null = a GLOBAL/platform suppression (applies to
/// everyone); otherwise scoped to one tenant. Enforced pre-call (extends the Day-10 gate).
model Suppression {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @db.Uuid
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone     String // normalized comparison key
  reason    String?
  createdAt DateTime @default(now())

  @@unique([tenantId, phone])
  @@index([phone])
}

/// Per-tenant enterprise SSO/SAML connection + directory-sync config (Day 59). One per tenant.
/// The x509 cert / entryPoint live in `config`; the SCIM bearer token is stored HASHED only.
model SsoConnection {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @unique @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider      String // WORKOS | SAML | OIDC
  config        Json     @default("{}") // entryPoint, issuer, x509 cert, connectionId
  roleMappings  Json     @default("{}") // IdP group → VocalIQ Role
  defaultRole   Role     @default(AGENT)
  scimTokenHash String? // sha256 of the SCIM bearer token (never plaintext)
  scimEnabled   Boolean  @default(false)
  enabled       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

model FeatureFlag {
  id       String           @id @default(uuid()) @db.Uuid
  scope    FeatureFlagScope
  key      String
  value    Json             @default("false")
  tenantId String?          @db.Uuid
  tenant   Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([scope, key, tenantId])
  @@index([tenantId])
}
