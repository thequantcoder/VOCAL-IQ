model Call {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @db.Uuid
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId       String        @db.Uuid
  agent         Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  flowVersionId String?       @db.Uuid
  flowVersion   FlowVersion?  @relation(fields: [flowVersionId], references: [id], onDelete: SetNull)
  contactId     String?       @db.Uuid
  contact       Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  direction     CallDirection
  channel       CallChannel
  status        CallStatus    @default(QUEUED)
  startedAt     DateTime?
  endedAt       DateTime?
  durationSec   Int?
  recordingUrl  String?
  attestation   String? // STIR/SHAKEN attestation level for this call (A|B|C|none) — Day 69
  // AI disclosure compliance (Day 71) — the defensible record of what was disclosed + opt-out.
  disclosureText String?
  disclosedAt    DateTime?
  humanOptOutAt  DateTime?
  disposition   String?
  sentiment     Float?
  costBreakdown Json          @default("{}") // {stt, llm, tts, telephony, total}
  experimentId  String?       @db.Uuid // A/B experiment this call was routed through (Day 30)
  variant       String? // the variant id assigned for that experiment
  experiment    Experiment?   @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())

  transcript   Transcript?
  usageRecords UsageRecord[]
  qaScores     QaScore[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([agentId])
  @@index([experimentId, variant])
}

// WhatsApp (Meta) Business Calling — the lifecycle record for a WhatsApp voice call (WAC-02). Kept
// separate from `Call` because the WhatsApp `connect` webhook arrives BEFORE agent routing (Call
// requires an agentId), so this row tracks the WhatsApp-specific lifecycle + payloads and links to
// the unified `Call` (with agent/transcript/cost) once the agent answers (WAC-04). Tenant-scoped (RLS).
model WhatsAppCall {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  waCallId         String // Meta WhatsApp call id (WACID)
  direction        String // USER_INITIATED | BUSINESS_INITIATED
  status           String    @default("connecting") // connecting|ringing|accepted|rejected|completed|failed
  fromNumber       String?
  toNumber         String?
  waUserId         String? // business-scoped user id (BSUID)
  ctaPayload       String? // from a call button (context for the AI agent)
  deeplinkPayload  String? // from a wa.me/call deep link
  permissionStatus String?
  callId           String?   @db.Uuid // link to the unified Call once the agent answers (WAC-04)
  errorCode        Int? // Meta calling error code on failure
  startedAt        DateTime?
  endedAt          DateTime?
  durationSec      Int?
  // Cost metering (WAC-06): set once, atomically, when the terminated call is metered.
  costUsd          Float? // WhatsApp carrier cost (inbound = 0; outbound = per-country pulse×tier)
  billedCountry    String? // ISO-2 destination used for the outbound rate (audit)
  billedAt         DateTime? // idempotency guard — non-null ⇒ already metered (never double-charge)
  createdAt        DateTime  @default(now())

  @@unique([tenantId, waCallId])
  @@index([tenantId])
  @@index([tenantId, status])
}

// Monthly WhatsApp OUTBOUND volume per tenant (WAC-06) — drives the volume-tier rate selection.
// Meta bills business-initiated calls at a lower per-minute rate once monthly volume crosses a band;
// this running total (billed 6-s-pulse seconds, this calendar month) picks tier0 vs tier1. Keyed by
// (tenant, period) so it resets naturally each month. Tenant-scoped (RLS).
model WhatsAppCallVolume {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period        String // YYYY-MM
  billedSeconds Int      @default(0) // cumulative outbound billed seconds this month (pulse-rounded)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId])
}

// Append-only audit of every WhatsApp calling webhook (WAC-02) — for replay/debug + idempotency.
model WhatsAppCallEvent {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  waCallId  String
  event     String // connect|status|terminate|permission_reply|settings_update|restriction
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([tenantId, waCallId])
}

/// WhatsApp outbound-calling permission per business↔user pair (WAC-08). Meta only lets the USER grant/
/// revoke; a temporary grant lasts 7 days with NO expiry webhook, so we track `expiresAt` locally and
/// re-evaluate on read. `consecutiveUnanswered` drives the auto-revoke back-off (4 → Meta revokes).
model WhatsAppCallPermission {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @db.Uuid
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  waId                 String // the user's WhatsApp number (digits)
  contactId            String?   @db.Uuid
  contact              Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  status               String    @default("no_permission") // no_permission | temporary | permanent
  expiresAt            DateTime? // temporary grants only (local clock — Meta sends no expiry webhook)
  source               String    @default("request") // request | callback | profile
  consecutiveUnanswered Int      @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([tenantId, waId])
  @@index([tenantId])
}

/// An audit row per permission-request message sent (WAC-08), so the 1/24h + 2/7d send caps can be
/// enforced from our own history (independent of Meta's `call_permissions.actions[].limits`).
model WhatsAppPermissionRequest {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  waId      String
  createdAt DateTime @default(now())

  @@index([tenantId, waId, createdAt])
}

