model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorUserId String?  @db.Uuid
  action      String
  target      String?
  meta        Json     @default("{}")
  ts          DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, ts])
}

/// A sentiment-triggered live-action rule (Day 73) — per-tenant, optionally per-agent.
model SentimentRule {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId     String?  @db.Uuid // null = applies to all the tenant's agents
  metric      String // sentimentScore | anger | frustration | buyingIntent
  operator    String // gt | lt
  threshold   Float
  action      String // escalate | alert_supervisor | tone_shift | tag | pause
  cooldownSec Int      @default(30)
  tag         String?
  toneHint    String?
  note        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([tenantId, active])
  @@index([tenantId, agentId])
}

/// A fired sentiment action (Day 73) — the live trace + the DB-backed cooldown source per call.
model SentimentEvent {
  id       String   @id @default(uuid()) @db.Uuid
  tenantId String   @db.Uuid
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId   String   @db.Uuid
  ruleId   String   @db.Uuid
  action   String
  metric   String
  value    Float
  ts       DateTime @default(now())

  @@index([tenantId, callId])
  @@index([callId, ruleId, ts])
}

/// A post-call AI copilot draft (Day 74) — auto-notes + a disposition the HUMAN confirms/edits.
/// The AI never finalizes: `confirmed` flips only on an explicit human action.
model CoachNote {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId      String    @db.Uuid
  disposition String
  notes       String
  confirmed   Boolean   @default(false)
  confirmedBy String?   @db.Uuid // the membership that confirmed
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId, callId])
}

/// A live Co-Pilot session on a HUMAN-led call (Day 90) — the standalone wedge product. Not tied to a
/// VocalIQ Agent or Call: a rep runs it over their own softphone/SIP/web call. Holds the transcribed
/// turns + a post-call CRM DRAFT the human confirms. Tenant-scoped via RLS.
model CopilotSession {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String?   @db.Uuid // the rep (membership user) who owns the session
  membershipId String?   @db.Uuid
  title        String?
  contactName  String?
  company      String?
  channel      String    @default("web") // web | sip | phone
  status       String    @default("live") // live | ended
  turns        Json      @default("[]") // [{ role: 'caller'|'agent', text }] — capped
  crmDraft     Json? // { contactName, company, email, phone, summary, nextSteps[], disposition }
  crmConfirmed Boolean   @default(false)
  durationSec  Int       @default(0)
  model        String? // the model that produced the CRM draft (audit)
  createdAt    DateTime  @default(now())
  endedAt      DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
}

/// A tenant-authored competitor battlecard (Day 90) — cue keywords that surface it live + talking
/// points the rep sees (agent-only). Tenant-scoped via RLS.
model Battlecard {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitor    String
  cues          String[] // keywords/phrases that trigger the card
  talkingPoints Json     @default("[]") // string[]
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

/// An enrolled caller voiceprint (Day 91) — voice-biometric identity for secure flows. The embedding
/// is stored ENCRYPTED at rest (envelope encryption) in `vector` and is NEVER returned raw. Enrollment
/// requires explicit biometric consent (`consentAt`) and is region-gated. Tenant-scoped via RLS.
model Voiceprint {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId String // the enrolled identity (contact/customer ref)
  region    String // the region the enrollment was captured + is legal in
  provider  String // the biometrics provider that produced the embedding (audit)
  dims      Int // embedding dimensionality (audit; the raw vector is never exposed)
  vector    Bytes // the embedding, envelope-encrypted — never stored or returned in the clear
  consentAt DateTime // when explicit biometric consent was recorded
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, contactId]) // one active enrollment per contact
  @@index([tenantId])
}

/// An immutable audit of every biometric action (Day 91) — enroll / verify / erase. Records the
/// outcome + scores (never the raw sample or embedding). Tenant-scoped via RLS.
model VoiceprintAudit {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId String
  event     String // enroll | verify | erase
  outcome   String? // verified | step_up | spoof | enrolled | erased
  score     Float?
  liveness  Float?
  region    String?
  createdAt DateTime @default(now())

  @@index([tenantId, contactId])
}

/// A digital-human / video avatar in a tenant's catalogue (Day 92). A `custom` avatar is a real
/// person's likeness → it carries a `likenessConsentAt` (consent is required to create it). Tenant-
/// scoped via RLS.
model Avatar {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  provider         String // the avatar/video provider (e.g. heygen | d-id | mock)
  providerAvatarId String // the provider's opaque avatar/actor id
  kind             String    @default("stock") // stock | custom
  likenessConsentAt DateTime? // set when a custom (real-likeness) avatar is consented
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId])
}

/// A video-avatar session (Day 92) — a rendered digital human on a video/web channel. Video is
/// expensive + plan-gated: a session either runs as `video` (metered per second) or AUTO-FALLS BACK to
/// `voice` when the plan/provider/avatar isn't available. Cost is attributed to the tenant. RLS-scoped.
model AvatarSession {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId        String?   @db.Uuid
  avatarId       String?   @db.Uuid
  mode           String    @default("voice") // video | voice
  fallback       Boolean   @default(false)
  fallbackReason String? // plan | provider_unavailable | no_avatar
  status         String    @default("active") // active | ended
  seconds        Int       @default(0)
  costUsd        Float     @default(0)
  providerRef    String? // the provider's session handle (video only)
  createdAt      DateTime  @default(now())
  endedAt        DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
}

/// A business signal mined from a call transcript (Day 75) — objection/buying/competitor/etc.
model CallSignal {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId    String   @db.Uuid
  type      String // objection | buying_signal | competitor | feature_request | churn_risk
  label     String // normalized label (objection tag, competitor name, buying-signal kind, …)
  quote     String?
  createdAt DateTime @default(now())

  @@index([tenantId, type, createdAt])
  @@index([tenantId, callId])
  @@index([tenantId, label])
}

/// Per-tenant conversation-intelligence config (Day 75): competitor watchlist + alert thresholds.
model ConversationIntelConfig {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @unique @db.Uuid
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  competitors String[] @default([])
  alertRules  Json     @default("[]") // [{ type, label?, threshold }]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// A per-tenant custom/fine-tuned LLM profile (Day 76): a base model + brand system-prompt and an
/// OPTIONAL provider fine-tune id. Strictly tenant-scoped (RLS) + consent-recorded — never shared.
model CustomModel {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  provider     Provider
  baseModel    String
  fineTuneId   String? // the provider's fine-tune model id once trained (gated)
  systemPrompt String? // brand tone / domain instructions
  status       String   @default("ready") // draft | training | ready | failed
  consentBy    String // who authorised (mandatory — consent gate)
  consentText  String // what was agreed (mandatory)
  consentAt    DateTime @default(now())
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, active])
}

/// A pay-by-voice payment (Day 78) — a customer of the tenant paying the tenant over a call.
/// PCI out-of-scope: the card is captured by a PCI provider, so this row NEVER holds a PAN/CVV —
/// only an opaque provider ref/token + `last4`. Integer minor units (cents), never floats.
model Payment {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId         String?   @db.Uuid
  agentId        String?   @db.Uuid
  amountCents    Int
  currency       String    @default("USD")
  refundedCents  Int       @default(0)
  status         String    @default("pending") // pending|authorized|succeeded|failed|refunded|partially_refunded
  provider       String    @default("PCI") // capture provider name
  providerRef    String? // opaque charge id (safe to store)
  token          String? // provider payment-method token (safe; NEVER a card number)
  last4          String? // ONLY card-derived value we may keep
  description    String?
  receiptChannel String    @default("none")
  receiptTo      String?
  receiptSentAt  DateTime?
  idempotencyKey String? // makes a retry safe — the same key never charges twice
  lastRefundKey  String? // idempotency for the most recent refund (safe retry of a partial refund)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status])
  @@index([tenantId, callId])
}

/// A caller-requested callback (Day 80) — auto-dialed at the requested time, within legal calling
/// hours evaluated in the caller's timezone. Tenant-scoped via RLS.
model Callback {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @db.Uuid
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId       String?   @db.Uuid
  contactId     String?   @db.Uuid
  callId        String? // the call the request came from (free text — inbound may have none)
  phone         String
  requestedAt   DateTime // UTC instant the caller wants to be called
  timezone      String    @default("UTC") // caller IANA tz — decides the local calling window
  note          String?
  status        String    @default("scheduled") // scheduled|dialing|completed|failed|cancelled|missed
  attempts      Int       @default(0)
  nextAttemptAt DateTime? // set when a prior attempt missed
  lastCallId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([status, requestedAt]) // scheduler sweep for due callbacks across tenants
}

/// A closed-revenue event (Day 81) — a won deal / booking / payment attributed to the dimensions that
/// drove it (agent/campaign/script/voice + the originating call/lead). ROI is revenue vs metered cost.
model RevenueEvent {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amountCents   Int
  currency      String   @default("USD")
  source        String   @default("manual") // manual | payment | crm
  occurredAt    DateTime @default(now())
  callId        String?  @db.Uuid
  leadId        String?  @db.Uuid
  agentId       String?  @db.Uuid
  campaignId    String?  @db.Uuid
  flowVersionId String?  @db.Uuid
  voiceId       String?  @db.Uuid
  note          String?
  createdAt     DateTime @default(now())

  @@index([tenantId, occurredAt])
  @@index([tenantId, agentId])
  @@index([tenantId, campaignId])
}

/// Per-tenant price for a billable outcome type (Day 82). `markupBps` is the reseller markup.
model OutcomePrice {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type       String // qualified_lead | booking | payment
  priceCents Int      @default(0)
  markupBps  Int      @default(0)
  active     Boolean  @default(true)
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, type])
  @@index([tenantId])
}

/// A billed business outcome (Day 82) — the auditable record of one verified outcome charged to the
/// tenant. The unique (tenantId, type, refId) means an outcome is billed AT MOST ONCE (anti-gaming).
model BillableOutcome {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type               String // qualified_lead | booking | payment
  refId              String // the lead/appointment/payment id the outcome refers to
  status             String   @default("billed") // billed | disputed | refunded
  priceCents         Int // wholesale price at billing time
  retailCents        Int // what the customer was charged (wholesale + reseller markup)
  resellerTenantId   String?  @db.Uuid
  resellerMarginCents Int     @default(0)
  period             String? // reseller-margin accrual period (YYYY-MM) — for exact dispute reversal
  note               String?
  occurredAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tenantId, type, refId])
  @@index([tenantId, status])
  @@index([tenantId, occurredAt])
}

/// A marketplace listing (Day 83) — a creator's published agent snapshot, sold + cloned to buyers.
/// A creator's own listings are RLS-scoped; APPROVED listings are browsable across tenants (via the
/// admin client, filtered to status='approved') — the only cross-tenant-visible marketplace data.
model MarketplaceListing {
  id              String    @id @default(uuid()) @db.Uuid
  creatorTenantId String    @db.Uuid
  creator         Tenant    @relation("MarketplaceCreator", fields: [creatorTenantId], references: [id], onDelete: Cascade)
  sourceAgentId   String?   @db.Uuid
  title           String
  description     String    @default("")
  priceCents      Int       @default(0)
  revShareBps     Int       @default(7000) // the creator's share (70% by default)
  status          String    @default("draft") // draft | pending | approved | rejected | delisted
  snapshot        Json      @default("{}") // {name, systemPrompt, graph, type, languages} captured at publish
  version         Int       @default(1)
  ratingSum       Int       @default(0)
  ratingCount     Int       @default(0)
  purchaseCount   Int       @default(0)
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([creatorTenantId, status])
}

/// A marketplace purchase (Day 83) — a buyer acquired + cloned a listing. Unique per (buyer, listing)
/// so a buyer pays once; the price split (creator/platform) is snapshotted for audit.
model MarketplacePurchase {
  id             String   @id @default(uuid()) @db.Uuid
  buyerTenantId  String   @db.Uuid
  buyer          Tenant   @relation("MarketplaceBuyer", fields: [buyerTenantId], references: [id], onDelete: Cascade)
  listingId      String   @db.Uuid
  pricePaidCents Int
  creatorCents   Int
  platformCents  Int
  clonedAgentId  String?  @db.Uuid
  createdAt      DateTime @default(now())

  @@unique([buyerTenantId, listingId])
  @@index([buyerTenantId])
  @@index([listingId])
}

/// A marketplace review (Day 83) — one rating/comment per buyer per listing.
model MarketplaceReview {
  id            String   @id @default(uuid()) @db.Uuid
  buyerTenantId String   @db.Uuid
  buyer         Tenant   @relation("MarketplaceReviewer", fields: [buyerTenantId], references: [id], onDelete: Cascade)
  listingId     String   @db.Uuid
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  @@unique([buyerTenantId, listingId])
  @@index([listingId])
}

/// A developer app (Day 84) — a third-party integration published by a developer tenant. Declares the
/// API scopes it needs + webhook events it subscribes to; the platform reviews + security-scans it;
/// approved apps are browsable cross-tenant. Client credentials identify the app (secret hashed at
/// rest). Approved apps are read via the admin client filtered to status='approved'.
model DeveloperApp {
  id                String   @id @default(uuid()) @db.Uuid
  developerTenantId String   @db.Uuid
  developer         Tenant   @relation("AppDeveloper", fields: [developerTenantId], references: [id], onDelete: Cascade)
  name              String
  description       String   @default("")
  homepageUrl       String?
  webhookUrl        String? // where the app receives subscribed events (SSRF-validated); internal, never public
  clientId          String   @unique // public OAuth-style client id (vqapp_...)
  hashedSecret      String   @unique // sha256 of the client secret (shown once at register/rotate)
  requestedScopes   String[] // the API scopes the app asks for (Day-48 catalogue; no wildcard)
  events            String[] @default([]) // subscribed webhook events
  priceCents        Int      @default(0) // one-time install fee (0 = free)
  revShareBps       Int      @default(7000) // the developer's share (70% by default)
  status            String   @default("draft") // draft | pending | approved | rejected | suspended
  scanFindings      Json     @default("[]") // the security-scan report at the last submit
  installCount      Int      @default(0)
  reviewedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  installs AppInstall[]

  @@index([status])
  @@index([developerTenantId, status])
}

/// An app install (Day 84) — a tenant installed a developer app, consenting to a subset of its scopes.
/// Installation mints a tenant-scoped API key (apiKeyId) limited to the granted scopes; uninstall
/// revokes it. Unique per (installer, app) so a tenant installs once; the paid split is snapshotted.
model AppInstall {
  id                String   @id @default(uuid()) @db.Uuid
  installerTenantId String   @db.Uuid
  installer         Tenant   @relation("AppInstaller", fields: [installerTenantId], references: [id], onDelete: Cascade)
  appId             String   @db.Uuid
  app               DeveloperApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  grantedScopes     String[] // the scopes the tenant consented to (⊆ the app's requestedScopes)
  apiKeyId          String?  @db.Uuid // the scoped key minted for the app (null until install completes)
  pricePaidCents    Int      @default(0)
  developerCents    Int      @default(0)
  platformCents     Int      @default(0)
  status            String   @default("pending") // pending | active | revoked
  consentedAt       DateTime?
  revokedAt         DateTime?
  createdAt         DateTime @default(now())

  @@unique([installerTenantId, appId])
  @@index([installerTenantId])
  @@index([appId])
}

/// A visual workflow automation (Day 85) — a DAG of trigger/condition/action/delay/end nodes that
/// automates a cross-system business process. The graph is validated ACYCLIC before it can go active;
/// `triggerEvent` is denormalized so an incoming event can index the workflows that might fire.
model Workflow {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  graph        Json     @default("{\"nodes\":[],\"edges\":[]}") // {nodes, edges}
  triggerEvent String? // denormalized trigger event (call_ended | disposition_set | lead_status_changed)
  status       String   @default("draft") // draft | active | paused
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  runs WorkflowRun[]

  @@index([tenantId])
  @@index([tenantId, status, triggerEvent])
}

/// One execution of a workflow (Day 85) — durable + observable. `context` holds the trigger event +
/// accumulated vars; `currentNodeId` is the checkpoint a retry/delay resumes from.
model WorkflowRun {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflowId    String   @db.Uuid
  workflow      Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status        String   @default("running") // running | waiting | completed | failed
  context       Json     @default("{}") // { event, vars }
  currentNodeId String? // the node to resume at (checkpoint) — null before the first advance
  stepCount     Int      @default(0)
  error         String?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?

  steps WorkflowRunStep[]

  @@index([tenantId, workflowId])
  @@index([tenantId, status])
}

/// One executed node in a run (Day 85) — the observability log. Records the node, its outcome, and any
/// detail, so an operator can see exactly what a run did and why.
model WorkflowRunStep {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runId     String   @db.Uuid
  run       WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  nodeId    String
  nodeType  String // TRIGGER | CONDITION | ACTION | DELAY | END
  status    String // ok | skipped | error | branched | waiting
  detail    String?
  attempt   Int      @default(1)
  createdAt DateTime @default(now())

  @@index([tenantId, runId])
  @@index([runId])
}

/// A fraud/abuse case (Day 70) — the auditable record of an automated enforcement + its review.
model AbuseCase {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  score      Int
  action     String // throttle | pause_campaigns | suspend_tenant
  status     String   @default("open") // open | reviewing | resolved | dismissed
  reasons    String[] @default([])
  notes      String?
  resolvedBy String?  @db.Uuid
  resolvedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([tenantId, status])
  @@index([status])
}

/// A BI analytics export (Day 87) — a materialized CSV of a tenant's calls/usage over a window, for
/// piping into a warehouse/BI. The CSV is stored inline (bounded rows); larger deliveries to R2/S3/a
/// warehouse are a gated future sink. Tenant-scoped via RLS.
model AnalyticsExport {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind       String // calls | usage
  format     String   @default("csv")
  status     String   @default("ready") // ready | failed
  rowCount   Int      @default(0)
  fromTs     DateTime?
  toTs       DateTime?
  content    String?  @db.Text // the CSV body (bounded); null if delivered to an external sink
  error      String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
}

/// A scheduled export (Day 87) — a worker generates an {@link AnalyticsExport} of `kind` every cadence.
model ExportSchedule {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind      String // calls | usage
  cadence   String // daily | weekly
  active    Boolean  @default(true)
  lastRunAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([active, cadence])
}

/// A translated transcript (Day 88) — a call's segments + summary rendered into an operator's working
/// language, stored alongside the native transcript (dual-language). One per (call, target language).
model TranscriptTranslation {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId     String   @db.Uuid
  targetLang String
  segments   Json     @default("[]") // translated [{speaker, text, startMs, ...}]
  summary    String?
  model      String? // the model that served the translation (audit)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([callId, targetLang])
  @@index([tenantId])
}

/// The translation cache (Day 88) — a deduped utterance→translation store keyed by content hash +
/// target language, so identical text (a repeated caption, a re-run transcript) is translated ONCE
/// (instant + free on repeat — self-audit F/D). Tenant-scoped.
model TranslationCache {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceHash String
  sourceLang String   @default("auto") // the (detected/declared) source language — part of the key so
  targetLang String //                    identical text in DIFFERENT source languages never collides
  text       String   @db.Text // the translated text
  createdAt  DateTime @default(now())

  @@unique([tenantId, sourceHash, sourceLang, targetLang])
  @@index([tenantId])
}

/// A learning run (Day 89) — an analysis of an agent's TOP consent-eligible calls that distilled winning
/// patterns + proposed persona improvements. Suggestions carry an `applied` flag; applying one appends it
/// to the agent's system prompt (a reviewed, then test-validated, change). Tenant-scoped via RLS.
model LearningRun {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId       String   @db.Uuid
  status        String   @default("ready") // ready | failed | empty
  callsUsed     Int      @default(0)
  callsExcluded Int      @default(0) // excluded by the consent gate (audit)
  patterns      Json     @default("[]")
  suggestions   Json     @default("[]") // [{ id, title, text, applied }]
  model         String?
  error         String?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, agentId])
}

/// Agent Desk presence (Day 67) — a human agent's live availability + skills for transfer routing.
model AgentPresence {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membershipId   String   @unique @db.Uuid
  userId         String   @db.Uuid
  status         String   @default("away") // available | away | busy
  skills         String[] @default([])
  activeCalls    Int      @default(0)
  lastAssignedAt DateTime?
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
}

/// A live call queued/routed to a human agent (Day 67). The Transfer node / escalation creates one.
model TransferRequest {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @db.Uuid
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId               String    @db.Uuid
  handoffType          String    @default("cold") // warm | cold
  strategy             String    @default("round_robin")
  requiredSkill        String?
  warmSummary          String?
  status               String    @default("queued") // queued | ringing | active | completed | abandoned
  assignedMembershipId String?   @db.Uuid
  waitStartedAt        DateTime  @default(now())
  answeredAt           DateTime?
  endedAt              DateTime?

  @@index([tenantId, status])
  @@index([callId])
}

/// Per-turn voice-loop latency samples (Day 63) — powers the latency dashboard + SLO enforcement.
model CallLatency {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId    String?  @db.Uuid
  sttMs     Int
  llmTtftMs Int
  ttsTtfaMs Int
  networkMs Int
  totalMs   Int
  provider  String?
  region    String?
  ts        DateTime @default(now())

  @@index([tenantId, ts])
}

/// Recording-disclosure / consent capture (Day 60). One row per consent event, region-aware.
model ConsentRecord {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactPhone String
  region       String
  channel      String   @default("voice")
  granted      Boolean
  basis        String?
  ts           DateTime @default(now())

  @@index([tenantId, contactPhone])
}

/// Do-Not-Call suppression (Day 60). tenantId null = a GLOBAL/platform suppression (applies to
/// everyone); otherwise scoped to one tenant. Enforced pre-call (extends the Day-10 gate).
model Suppression {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @db.Uuid
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone     String // normalized comparison key
  reason    String?
  createdAt DateTime @default(now())

  @@unique([tenantId, phone])
  @@index([phone])
}

/// Per-tenant enterprise SSO/SAML connection + directory-sync config (Day 59). One per tenant.
/// The x509 cert / entryPoint live in `config`; the SCIM bearer token is stored HASHED only.
model SsoConnection {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @unique @db.Uuid
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider      String // WORKOS | SAML | OIDC
  config        Json     @default("{}") // entryPoint, issuer, x509 cert, connectionId
  roleMappings  Json     @default("{}") // IdP group → VocalIQ Role
  defaultRole   Role     @default(AGENT)
  scimTokenHash String? // sha256 of the SCIM bearer token (never plaintext)
  scimEnabled   Boolean  @default(false)
  enabled       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

model FeatureFlag {
  id       String           @id @default(uuid()) @db.Uuid
  scope    FeatureFlagScope
  key      String
  value    Json             @default("false")
  tenantId String?          @db.Uuid
  tenant   Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([scope, key, tenantId])
  @@index([tenantId])
}
