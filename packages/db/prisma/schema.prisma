model Plan {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String?        @db.Uuid // null = platform/global plan
  tenant            Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String
  priceMonthly      Int            @default(0) // minor units of `currency`
  currency          String         @default("USD")
  includedMinutes   Int            @default(0)
  agentLimit        Int            @default(1)
  numberLimit       Int            @default(0)
  sipLimit          Int            @default(0)
  features          Json           @default("{}")
  overageRatePerMin Int            @default(0) // minor units
  isResellerPlan    Boolean        @default(false)
  // No-code plan builder (Day 56): Stripe linkage + versioning for grandfathering.
  stripeProductId   String? // set on Stripe sync (gated until STRIPE_* keys)
  stripePriceId     String?
  version           Int            @default(1)
  active            Boolean        @default(true) // archived/superseded plans are inactive
  supersededById    String?        @db.Uuid // → the newer version that replaced this one
  supersededBy      Plan?          @relation("PlanVersion", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes        Plan[]         @relation("PlanVersion")
  createdAt         DateTime       @default(now())
  subscriptions     Subscription[]

  @@index([tenantId])
  @@index([tenantId, active])
}

model Subscription {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @db.Uuid
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId           String             @db.Uuid
  plan             Plan               @relation(fields: [planId], references: [id])
  status           SubscriptionStatus @default(TRIALING)
  processor        String?
  externalId       String?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())

  @@index([tenantId])
}

model Wallet {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @unique @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  balanceCents Int      @default(0) // prepaid credits (cached; = sum of ledger entries)
  bonusCents   Int      @default(0) // bonus / perk credits (Day 49; drained first)
  currency     String   @default("USD")
  autoRecharge Json     @default("{}")
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

// Append-only wallet ledger (Day 53). Every top-up/charge/refund is an immutable entry; the
// balance is the sum. `idempotencyKey` is unique per tenant so replaying a charge NEVER
// double-debits (self-audit C). Integer minor units (cents) only — never floats.
model WalletLedger {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amountCents    Int // PAID portion moved (positive = credit, negative = debit); balance = sum of these
  promoCents     Int      @default(0) // promo/bonus portion of this charge (funded from CreditGrants, not balance)
  currency       String   @default("USD")
  reason         String
  idempotencyKey String
  callId         String?  @db.Uuid // soft link to the charged call
  meta           Json     @default("{}") // pricing-chain snapshot for audit
  createdAt      DateTime @default(now())

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}

// How a credit grant was funded (PARITY-08). All are spent BEFORE paid balance and never withdraw
// as cash: PROMO (a redeemed promo code), BONUS (signup/perk), REFERRAL, MANUAL (an operator grant).
enum GrantKind {
  PROMO
  BONUS
  REFERRAL
  MANUAL
}

// Promotional / bonus credits (PARITY-08). A grant is a pool of credits that is consumed before the
// paid `Wallet.balanceCents`, can expire, and never pays out as cash. `remainingCents` is decremented
// (race-safe, FOR UPDATE) as usage is charged; `revokedAt` stops it being spent. Tenant-scoped (RLS).
model CreditGrant {
  id            String     @id @default(uuid()) @db.Uuid
  tenantId      String     @db.Uuid
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind          GrantKind
  source        String // human label: "signup-bonus", "promo:LAUNCH50", "manual: goodwill"…
  amountCents   Int // original grant size
  remainingCents Int // unspent balance (0 ≤ remaining ≤ amount); drained before paid credits
  currency      String     @default("USD")
  expiresAt     DateTime? // null = never expires
  revokedAt     DateTime? // set → excluded from spend + reporting
  createdBy     String?    @db.Uuid // operator (super-admin / reseller) who granted it, if any
  promoCode     PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  promoCodeId   String?    @db.Uuid
  createdAt     DateTime   @default(now())

  @@index([tenantId])
  @@index([tenantId, remainingCents])
  @@index([promoCodeId])
}

// A redeemable promo code (PARITY-08) — platform-global (no tenantId; accessed via the owner client).
// Redemption creates a tenant CreditGrant. Abuse-guarded by `maxRedemptions` (global cap) and
// `perTenantLimit` (default 1). `redeemedCount` is incremented race-safely on redemption.
model PromoCode {
  id             String        @id @default(uuid()) @db.Uuid
  code           String        @unique
  kind           GrantKind     @default(PROMO)
  amountCents    Int
  currency       String        @default("USD")
  maxRedemptions Int? // null = unlimited (subject to perTenantLimit)
  perTenantLimit Int           @default(1)
  redeemedCount  Int           @default(0)
  expiresAt      DateTime?
  active         Boolean       @default(true)
  createdBy      String?       @db.Uuid
  createdAt      DateTime      @default(now())
  grants         CreditGrant[]

  @@index([code])
}

// One record per metered provider call. Timescale hypertable (see RLS/extra SQL);
// the partition column `ts` is part of the primary key so the hypertable is valid.
model UsageRecord {
  id         String     @default(uuid()) @db.Uuid
  tenantId   String     @db.Uuid
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  callId     String?    @db.Uuid
  call       Call?      @relation(fields: [callId], references: [id], onDelete: SetNull)
  provider   Provider
  capability Capability
  units      Float
  costUsd    Float
  byok       Boolean    @default(false)
  ts         DateTime   @default(now())

  @@id([id, ts])
  @@index([tenantId, ts])
  @@index([callId])
}

model Invoice {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
