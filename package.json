{
  "name": "vocaliq",
  "version": "1.1.0",
  "private": true,
  "description": "VocalIQ — multi-tenant white-label Agentic Voice AI SaaS (monorepo)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:infra": "docker compose --env-file .env -f infra/docker-compose.yml up -d",
    "dev:infra:down": "docker compose --env-file .env -f infra/docker-compose.yml down",
    "dev:infra:reset": "docker compose --env-file .env -f infra/docker-compose.yml down -v",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "biome check --write .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "@nestjs/core",
      "sharp",
      "msgpackr-extract"
    ],
    "overrides": {
      "ioredis": "5.11.1",
      "qs@>=6.0.0 <6.15.2": ">=6.15.2",
      "postcss@<8.5.10": ">=8.5.10",
      "uuid@<11.1.1": ">=11.1.1",
      "rollup@>=3.0.0 <3.30.0": ">=3.30.0"
    }
  }
}
