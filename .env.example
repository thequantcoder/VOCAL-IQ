# VocalIQ — environment variable NAMES only (never put real values here).
# Copy to .env (git-ignored) and fill locally. Source of truth: docs/PREREQUISITES.md.
# Most are optional at Day 0; each becomes required on the day its feature is built.

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
VOICE_PORT=8000

# ── Group B: datastores (Phase 0–1) ───────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=

# ── Group B: storage (Cloudflare R2) ──────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# ── Group B: auth (Clerk) ─────────────────────────────────────────────────────
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ── Group B: telephony + media ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Group B: AI providers (STT/TTS/LLM/embeddings) ────────────────────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Group B: billing (Stripe) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Group B: observability + email ────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_HOST=
RESEND_API_KEY=

# ── Optional: secrets manager ─────────────────────────────────────────────────
DOPPLER_TOKEN=
