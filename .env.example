# VocalIQ — environment variable NAMES only (never put real values here).
# Copy to .env (git-ignored) and fill locally. Source of truth: docs/PREREQUISITES.md.
# Most are optional at Day 0; each becomes required on the day its feature is built.

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
VOICE_PORT=8000

# ── Local dev infra host-port overrides (infra/docker-compose.yml) ─────────────
# Only needed when a default port is already taken on your machine. Defaults:
# Postgres 5432, Redis 6379, LiveKit 7880. Set + match DATABASE_URL/REDIS_URL.
POSTGRES_PORT=5432
REDIS_PORT=6379
LIVEKIT_PORT=7880

# ── Group B: datastores (Phase 0–1) ───────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=
# Runtime app role (non-superuser, RLS-constrained). Defaults to DATABASE_URL if unset.
APP_DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=

# ── Group B: storage (Cloudflare R2) ──────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# ── Group B: auth (self-hosted, no third-party service) ───────────────────────
# JWT signing secret (min 16 chars), e.g. `openssl rand -base64 48`. Required by the API.
APP_JWT_SECRET=
# Key-vault master key (Day 57): 32 bytes, base64 — `openssl rand -base64 32`. Wraps the
# per-secret data keys for provider credentials. Set this in production; if unset, a DEV-ONLY
# derived key is used (fine for local/dev, NOT for production). A cloud KMS can swap in later.
VAULT_MASTER_KEY=
# Where the web dashboard reaches the API (browser-side). Behind Nginx in prod this is
# your public API URL, e.g. https://yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Group B: telephony + media ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Telnyx — alternative carrier (number provisioning + Call Control telephony).
# TELNYX_API_KEY enables Telnyx search/buy/release; TELNYX_CONNECTION_ID is the
# Call Control Connection outbound calls are placed on.
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
# Plivo — alternative carrier (number provisioning + Voice API telephony).
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── WhatsApp Business Calling (WAC) ───────────────────────────────────────────
# Managed-mode creds for the calling adapter + webhook. TEST_* are the sandbox/test
# number (dev); the non-TEST pair is the production number. META_APP_SECRET verifies
# the `calls` webhook HMAC; META_WEBHOOK_VERIFY_TOKEN is the subscription handshake.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEST_ACCESS_TOKEN=
WHATSAPP_TEST_PHONE_NUMBER_ID=
WHATSAPP_TEST_WABA_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
# api → voice internal control hop for the WhatsApp WebRTC media bridge (WAC-03).
# Both must be set to enable live media; the same secret is VOICE_INTERNAL_SECRET on
# both sides. Unset → media gated (calls are recorded but stay `connecting`).
VOICE_SERVICE_URL=http://localhost:8000
VOICE_INTERNAL_SECRET=

# ── Group B: AI providers (STT/TTS/LLM/embeddings) ────────────────────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# OpenRouter — one key, many models (OpenAI-compatible); models are namespaced (openai/gpt-4o-mini).
OPENROUTER_API_KEY=

# ── Group B: billing (Stripe) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Group B: observability + email ────────────────────────────────────────────
# Server-side (api) Sentry + PostHog. All optional — absent = integration disabled.
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=
# Client-side (web) — NEXT_PUBLIC_* are exposed to the browser bundle by design.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
RESEND_API_KEY=

# ── Optional: secrets manager ─────────────────────────────────────────────────
DOPPLER_TOKEN=

# Web → API base URL (dashboard data layer, Day 14)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Local dev on iCloud-synced folders (macOS) ────────────────────────────────
# If this repo lives under iCloud Drive, macOS can evict Next's default `.next`
# build chunks mid-session → the dashboard shows "Something went wrong" with
# stale/broken routes. Set the build dir to a `.nosync` folder (iCloud skips it)
# so `pnpm dev` + `pnpm build` stay stable. No-op in CI/prod (leave unset).
NEXT_DIST_DIR=.next.nosync

# ── Self-host: version + Check-for-Updates (PARITY-11) ────────────────────────
# The installed version is baked at build from the root VERSION file:
#   export APP_VERSION=$(cat VERSION)
# The super-admin "Check for Updates" card fetches this manifest and compares it
# to APP_VERSION (read-only — it NEVER auto-applies). Leave unset on hosted SaaS.
APP_VERSION=
UPDATE_MANIFEST_URL=https://raw.githubusercontent.com/thequantcoder/VOCAL-IQ/main/infra/releases.json
