{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      // DB connection strings the @vocaliq/db tests need (Turbo strict env mode
      // strips undeclared vars; locally dotenv loads them, in CI the job sets them).
      "env": ["DATABASE_URL", "DIRECT_URL", "APP_DATABASE_URL", "REDIS_URL"],
      "outputs": ["coverage/**"]
    }
  }
}
